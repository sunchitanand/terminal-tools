#!/usr/bin/env zsh
# cmux-tunnel — persistent SSH tunnel for cmux socket forwarding
# Usage: cmux-tunnel <host>
#        cmux-tunnel stop [host]
#        cmux-tunnel status

HOST="${1:-}"
REMOTE_SOCK="/tmp/cmux.sock"
LOCAL_SOCK="${CMUX_SOCKET_PATH:-$HOME/Library/Application Support/cmux/cmux.sock}"
PID_DIR="$HOME/.cmux-tunnels"

mkdir -p "$PID_DIR"

if [[ "$HOST" == "status" ]]; then
    for pf in "$PID_DIR"/*.pid(N); do
        h=$(basename "$pf" .pid | tr '_' '.')
        pid=$(cat "$pf")
        kill -0 "$pid" 2>/dev/null && echo "✓ $h (PID $pid)" || { echo "✗ $h (dead)"; rm -f "$pf"; }
    done
    exit 0
fi

if [[ "$HOST" == "stop" ]]; then
    HOST="${2:-}"
    if [[ -z "$HOST" ]]; then
        for pf in "$PID_DIR"/*.pid(N); do kill "$(cat "$pf")" 2>/dev/null; rm -f "$pf"; done
        echo "Stopped all tunnels"; exit 0
    fi
    PID_FILE="$PID_DIR/$(echo "$HOST" | tr '/' '_').pid"
    [[ -f "$PID_FILE" ]] && kill "$(cat "$PID_FILE")" 2>/dev/null && rm -f "$PID_FILE" && echo "Stopped $HOST" || echo "No tunnel for $HOST"
    exit 0
fi

[[ -z "$HOST" ]] && { echo "Usage: cmux-tunnel <host> | stop [host] | status"; exit 1; }
[[ ! -S "$LOCAL_SOCK" ]] && { echo "cmux socket not found at $LOCAL_SOCK"; exit 1; }

PID_FILE="$PID_DIR/$(echo "$HOST" | tr '/' '_').pid"
[[ -f "$PID_FILE" ]] && kill "$(cat "$PID_FILE")" 2>/dev/null

# Get cmux env vars (from current env or query cmux)
local ws_id="${CMUX_WORKSPACE_ID:-}"
local tab_id="${CMUX_TAB_ID:-}"
local panel_id="${CMUX_PANEL_ID:-}"
local surface_id="${CMUX_SURFACE_ID:-}"

# Build the export line for remote .zshrc
EXPORT_LINE="export CMUX_SOCKET_PATH=$REMOTE_SOCK CMUX_WORKSPACE_ID=$ws_id CMUX_TAB_ID=$tab_id CMUX_PANEL_ID=$panel_id CMUX_SURFACE_ID=$surface_id"

# Clean stale socket, set tmux env + shell env on remote
ssh -o ControlPath=none -o LogLevel=ERROR "$HOST" "
    rm -f $REMOTE_SOCK
    PATH=/usr/local/bin:\$PATH
    tmux set-environment -g CMUX_SOCKET_PATH '$REMOTE_SOCK' 2>/dev/null
    tmux set-environment -g CMUX_WORKSPACE_ID '$ws_id' 2>/dev/null
    tmux set-environment -g CMUX_TAB_ID '$tab_id' 2>/dev/null
    tmux set-environment -g CMUX_PANEL_ID '$panel_id' 2>/dev/null
    tmux set-environment -g CMUX_SURFACE_ID '$surface_id' 2>/dev/null
    # Update .zshrc — replace existing cmux export or add new
    sed -i '/^export CMUX_SOCKET_PATH=/d' ~/.zshrc 2>/dev/null
    echo '$EXPORT_LINE' >> ~/.zshrc
" 2>/dev/null

# Start persistent tunnel — auto-reconnects
(
    while true; do
        ssh -o ServerAliveInterval=15 \
            -o ServerAliveCountMax=3 \
            -o StreamLocalBindUnlink=yes \
            -o ControlPath=none \
            -o LogLevel=ERROR \
            -N \
            -R "$REMOTE_SOCK:$LOCAL_SOCK" \
            "$HOST" 2>/dev/null
        sleep 2
    done
) &!
echo "$!" > "$PID_FILE"

echo "✓ Tunnel to $HOST (PID $(cat "$PID_FILE"))"
