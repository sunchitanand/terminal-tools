#!/usr/bin/env zsh
# kiro-selector — TUI session manager for kiro-cli
# Uses kiro-cli's own --list-sessions for complete data (v1 + v2 + git-based)
# Caches results for instant startup; refreshes in background after display.

DB="$HOME/Library/Application Support/kiro-cli/data.sqlite3"
HOME_DIR="$HOME"
MAX_PER_DIR=5
CACHE_FILE="$HOME/.cache/kiro-selector/sessions.tsv"
CACHE_MAX_AGE=3600  # refresh if older than 1 hour

C=$'\e[36m' M=$'\e[35m' G=$'\e[32m' Y=$'\e[33m' D=$'\e[90m' R=$'\e[0m' B=$'\e[1m'
SEL=$'\e[44;97m'

typeset -a lines_text lines_type lines_dir lines_cid lines_selectable
typeset -i total_lines=0 sel=0 scroll=0
search=""
typeset -a _filt; _prev_search="__init__"

proj_name() {
    local p="${1/#$HOME_DIR\//}"
    case "$p" in
        Documents/projects/*) echo "projects/${${p#Documents/projects/}%%/*}" ;;
        Documents/code/*)     echo "code/${${p#Documents/code/}%%/*}" ;;
        playground/*)         echo "playground/${${p#playground/}%%/*}" ;;
        doc-reviews/*)        echo "doc-reviews" ;;
        scratch*)             echo "scratch" ;;
        *)                    echo "${p%%/*}" ;;
    esac
}

refresh_cache() {
    # Slow: fetches from kiro-cli in parallel, writes TSV cache
    mkdir -p "${CACHE_FILE:h}"
    typeset -a all_dirs
    while IFS= read -r d; do
        [[ -d "$d" ]] && all_dirs+=("$d")
    done < <(sqlite3 "$DB" "SELECT DISTINCT key FROM conversations_v2" 2>/dev/null)

    local tmpdir=$(mktemp -d)
    for d in "${all_dirs[@]}"; do
        local hash=$(echo "$d" | /sbin/md5 -q 2>/dev/null || echo "$d" | md5sum | cut -c1-8)
        (cd "$d" && kiro-cli chat --list-sessions 2>"$tmpdir/${hash}.raw" >/dev/null) &
    done
    wait

    python3 << PYEOF > "${CACHE_FILE}.tmp" 2>/dev/null
import os, re, glob, shlex
ansi_re = re.compile(r'\x1b\[[0-9;]*m')
session_re = re.compile(r'^\s+(\d+ \w+ ago|just now)\s+\|\s+(.*?)\s+\|\s+(\d+) msgs\s+\|\s+(v[12])\s*$')
dir_re = re.compile(r'^Chat sessions for (.+):')
sid_re = re.compile(r'^Chat SessionId:\s+(\S+)')
home = os.path.expanduser('~')
def short(p): return '~' + p[len(home):] if p.startswith(home) else p
def proj(p):
    r = p[len(home)+1:] if p.startswith(home+'/') else p
    for prefix, label in [('Documents/projects/', 'projects/'), ('Documents/code/', 'code/'),
                          ('playground/', 'playground/'), ('doc-reviews', 'doc-reviews')]:
        if r.startswith(prefix):
            parts = r[len(prefix):].split('/', 1)
            return label + (parts[0] if prefix != 'doc-reviews' else '')
    if r.startswith('scratch'): return 'scratch'
    return r.split('/')[0]
sessions = []
for f in glob.glob('$tmpdir/*.raw'):
    text = ansi_re.sub('', open(f).read())
    cur_dir = cur_cid = ''; count = 0
    for line in text.split('\n'):
        m = dir_re.match(line)
        if m: cur_dir = m.group(1).strip(); count = 0; continue
        m = sid_re.match(line)
        if m: cur_cid = m.group(1).strip(); continue
        m = session_re.match(line)
        if m and cur_dir and count < $MAX_PER_DIR:
            ago, title, msgs = m.group(1), m.group(2).strip()[:80], m.group(3)
            sessions.append((proj(cur_dir), cur_dir, short(cur_dir), cur_cid, ago, title, msgs))
            count += 1
from collections import OrderedDict
groups = OrderedDict()
for s in sessions:
    groups.setdefault(s[0], []).append(s)
for p in sorted(groups.keys()):
    print(f"H\t{p}")
    prev_dir = ''
    for _, dir_path, short_path, cid, ago, title, msgs in groups[p]:
        if short_path != prev_dir: print(f"D\t{short_path}"); prev_dir = short_path
        print(f"S\t{shlex.quote(title)}\t{shlex.quote(dir_path)}\t{shlex.quote(cid)}\t{ago}\t{msgs}")
PYEOF
    mv "${CACHE_FILE}.tmp" "$CACHE_FILE" 2>/dev/null
    rm -rf "$tmpdir"
}

build_from_cache() {
    # Fast: reads TSV cache into display arrays
    lines_text=(); lines_type=(); lines_dir=(); lines_cid=(); lines_selectable=()
    total_lines=0

    typeset -A running_dirs
    local pids=$(pgrep -f "kiro-cli/bun" 2>/dev/null | tr '\n' ',')
    if [[ -n "$pids" ]]; then
        pids="${pids%,}"
        while IFS= read -r cwd; do
            [[ -n "$cwd" ]] && running_dirs[$cwd]=1
        done < <(lsof -p "$pids" -d cwd -Fn 2>/dev/null | grep '^n/' | cut -c2-)
    fi

    [[ ! -f "$CACHE_FILE" ]] && return

    while IFS=$'\t' read -r ltype ltext ldir lcid lago lmsgs; do
        case "$ltype" in
            H)
                lines_text+=(""); lines_type+=("blank"); lines_dir+=(""); lines_cid+=(""); lines_selectable+=(0)
                lines_text+=("$ltext"); lines_type+=("header"); lines_dir+=(""); lines_cid+=(""); lines_selectable+=(0) ;;
            D)
                lines_text+=("$ltext"); lines_type+=("dir"); lines_dir+=(""); lines_cid+=(""); lines_selectable+=(0) ;;
            S)
                eval "local msg=$ltext dir=$ldir cid=$lcid"
                local dot="○"
                [[ -n "${running_dirs[$dir]}" ]] && dot="●"
                lines_text+=("$dot $msg%%${lmsgs}m · $lago"); lines_type+=("session"); lines_dir+=("$dir"); lines_cid+=("$cid")
                lines_selectable+=(1) ;;
        esac
    done < "$CACHE_FILE"
    total_lines=$#lines_text
}

fetch_and_build() {
    if [[ -f "$CACHE_FILE" ]]; then
        # Load from cache instantly
        build_from_cache
    else
        # First run — no cache, must fetch
        printf '  Loading sessions (first run)...\r'
        refresh_cache
        build_from_cache
    fi
}

# --- Search & Nav ---
line_matches() {
    [[ -z "$search" ]] && return 0
    [[ ${lines_selectable[$1]} -ne 1 ]] && return 1
    local short="${lines_dir[$1]/#$HOME_DIR/\~}"
    local needle="${(L)search}"
    local dir_hay="${(L)short}"
    [[ "$dir_hay" == *"$needle"* ]] && return 0
    local hi=1 ni=1
    while [[ $ni -le $#needle ]]; do
        [[ $hi -gt $#dir_hay ]] && return 1
        [[ "${dir_hay[$hi]}" == "${needle[$ni]}" ]] && ((ni++))
        ((hi++))
    done
    return 0
}

_line_score() {
    _score=3
    [[ ${lines_selectable[$1]} -ne 1 ]] && return
    local short="${lines_dir[$1]/#$HOME_DIR/\~}"
    local needle="${(L)search}"
    local dir_hay="${(L)short}"
    [[ "$dir_hay" == *"$needle"* ]] && { _score=0; return; }
    local hi=1 ni=1
    while [[ $ni -le $#needle ]]; do
        [[ $hi -gt $#dir_hay ]] && break
        [[ "${dir_hay[$hi]}" == "${needle[$ni]}" ]] && ((ni++))
        ((hi++))
    done
    [[ $ni -gt $#needle ]] && { _score=1; return; }
    local msg_hay="${(L)lines_text[$1]}"
    [[ "$msg_hay" == *"$needle"* ]] && { _score=2; return; }
}

next_sel() {
    local i=$((sel + 1)) start=$sel
    while (( i != start )); do
        (( i > total_lines )) && i=1
        [[ ${lines_selectable[i]} -eq 1 ]] && line_matches $i && { sel=$i; return; }
        ((i++)); (( i > total_lines )) && i=1
    done
}

prev_sel() {
    local i=$((sel - 1)) start=$sel
    while (( i != start )); do
        (( i < 1 )) && i=$total_lines
        [[ ${lines_selectable[i]} -eq 1 ]] && line_matches $i && { sel=$i; return; }
        ((i--)); (( i < 1 )) && i=$total_lines
    done
}

first_sel() {
    if [[ -z "$search" ]]; then
        sel=1
        while (( sel <= total_lines )); do
            [[ ${lines_selectable[sel]} -eq 1 ]] && return
            ((sel++))
        done
        sel=1; return
    fi
    local best_i=0 best_s=9 _score
    for i in {1..$total_lines}; do
        [[ ${lines_selectable[i]} -ne 1 ]] && continue
        _line_score $i
        (( _score < best_s )) && { best_s=$_score; best_i=$i; (( best_s == 0 )) && break; }
    done
    (( best_i > 0 )) && sel=$best_i
}

# --- Draw ---
draw() {
    local vis=$(( LINES - 5 ))
    [[ -n "$search" ]] && vis=$(( LINES - 6 ))

    if [[ "$search" != "$_prev_search" ]]; then
        _filt=()
        if [[ -z "$search" ]]; then
            for i in {1..$total_lines}; do _filt+=($i); done
        else
            typeset -A show_lines
            for i in {1..$total_lines}; do
                [[ ${lines_selectable[i]} -eq 1 ]] && line_matches $i && show_lines[$i]=1
            done
            typeset -a match_indices
            for k in ${(k)show_lines}; do match_indices+=($k); done
            for mi in $match_indices; do
                local jj=$((mi-1))
                while (( jj >= 1 )); do
                    [[ "${lines_type[jj]}" == "dir" ]] && { show_lines[$jj]=1; break; }; ((jj--))
                done
                while (( jj >= 1 )); do
                    [[ "${lines_type[jj]}" == "header" ]] && { show_lines[$jj]=1; (( jj > 1 )) && [[ "${lines_type[jj-1]}" == "blank" ]] && show_lines[$((jj-1))]=1; break; }; ((jj--))
                done
            done
            for i in {1..$total_lines}; do
                [[ -n "${show_lines[$i]}" ]] && _filt+=($i)
            done
        fi
        _prev_search="$search"
    fi
    local -a filt; filt=("${_filt[@]}")

    local sel_pos=0
    for fi in {1..$#filt}; do
        [[ ${filt[fi]} -eq $sel ]] && { sel_pos=$fi; break; }
    done
    if (( sel_pos > 0 )); then
        (( sel_pos <= scroll + 1 )) && scroll=$(( sel_pos > 3 ? sel_pos - 3 : 0 ))
        (( sel_pos > scroll + vis )) && scroll=$(( sel_pos - vis ))
    fi
    (( scroll < 0 )) && scroll=0

    printf '\e[H\e[J'
    printf '  %s⚡ kiro-cli sessions%s\r\n\r\n' "$M" "$R"

    for fi in {$((scroll+1))..$((scroll+vis))}; do
        (( fi > $#filt )) && { printf '\r\n'; continue; }
        local i=${filt[fi]}
        local t="${lines_type[i]}" txt="${lines_text[i]}"
        case "$t" in
            blank) printf '\r\n' ;;
            header) printf '  %s%s%s\r\n' "$B$M" "$txt" "$R" ;;
            dir) printf '    %s%s%s\r\n' "$C" "$txt" "$R" ;;
            session)
                local msg="${txt%%\%\%*}" ago="${txt#*\%\%}"
                local W=$(( COLUMNS - 10 )); (( W > 100 )) && W=100
                local ago_len=$(( ${#ago} + 2 ))
                local msg_w=$(( W - ago_len ))
                [[ ${#msg} -gt $msg_w ]] && msg="${msg[1,$((msg_w-2))]}.."
                if [[ $i -eq $sel ]]; then
                    printf '  %s  %-*s %s%s\r\n' "$SEL" $((W - ago_len)) "$msg" "$ago" "$R"
                else
                    local dot="${msg[1]}" rest="${msg[3,-1]}" dc="$D"
                    [[ "$dot" == "●" ]] && dc="$G"
                    printf '   %s%s%s %-*s %s%s%s\r\n' "$dc" "$dot" "$R" $((W - ago_len - 2)) "$rest" "$D" "$ago" "$R"
                fi ;;
        esac
    done

    printf '\r\n'
    if [[ -n "$search" ]]; then
        printf '  %s🔍%s %s%s%s█  %sesc%s clear\r\n' "$Y" "$R" "$C" "$search" "$R" "$D" "$R"
    else
        printf '  %s↑↓%s select  %s⏎%s resume  %s⌥n%s new  %s⌥d%s del  %s⌥r%s refresh  %s⌥q%s quit  %stype%s search\r\n' \
            "$D" "$R" "$D" "$R" "$D" "$R" "$D" "$R" "$D" "$R" "$D" "$R" "$D" "$R"
    fi
}

# --- Actions ---
cleanup() { printf '\e[?25h'; stty sane 2>/dev/null; kill $REFRESH_PID 2>/dev/null; }
trap cleanup EXIT INT TERM

do_resume() {
    [[ ${lines_selectable[sel]} -ne 1 ]] && return
    local dir="${lines_dir[sel]}"; [[ -z "$dir" ]] && return
    cleanup; cd "$dir" && exec kiro-cli chat --resume
}
do_new() {
    [[ ${lines_selectable[sel]} -ne 1 ]] && return
    local dir="${lines_dir[sel]}"; [[ -z "$dir" ]] && return
    cleanup; cd "$dir" && exec kiro-cli chat
}
do_delete() {
    [[ ${lines_selectable[sel]} -ne 1 ]] && return
    local cid="${lines_cid[sel]}" dir="${lines_dir[sel]}"
    local msg="${lines_text[sel]%%\%\%*}"; msg="${msg[3,42]}"
    stty sane; printf '\e[?25h'
    printf '\n  %sDelete "%s%s%s"? (y/n):%s ' "$C" "$M" "$msg" "$C" "$R"
    read -rsk1 confirm
    if [[ "$confirm" == "y" ]]; then
        (cd "$dir" && kiro-cli chat --delete-session "$cid" 2>/dev/null >/dev/null)
        fetch_and_build; first_sel
    fi
    stty -echo raw; printf '\e[?25l'
}

# --- Main ---
[[ ! -f "$DB" ]] && { echo "kiro-cli database not found"; exit 1; }

fetch_and_build
first_sel
stty -echo raw
printf '\e[?25l'
draw

# Refresh cache in background so next launch is fresh
refresh_cache &
REFRESH_PID=$!

while true; do
    while read -rsk1 -t 0 _d 2>/dev/null; do :; done
    read -rsk1 key
    if [[ "$key" == $'\e' ]]; then
        read -rsk1 -t 0.05 k2
        if [[ -z "$k2" ]]; then
            [[ -n "$search" ]] && { search=""; _prev_search="__init__"; first_sel; scroll=0; }
        elif [[ "$k2" == '[' || "$k2" == 'O' ]]; then
            read -rsk1 -t 0.05 k3; key="${key}${k2}${k3}"
        else
            key="opt-${k2}"
        fi
    fi

    case "$key" in
        $'\e[A'|$'\eOA') prev_sel ;;
        $'\e[B'|$'\eOB') next_sel ;;
        $'\n'|$'\r') do_resume ;;
        opt-n) do_new ;;
        opt-d) do_delete ;;
        opt-r)
            stty sane; printf '\e[?25h\e[H\e[J  Refreshing...\r'
            refresh_cache; build_from_cache; _prev_search="__init__"; first_sel; scroll=0
            stty -echo raw; printf '\e[?25l' ;;
        opt-q|$'\x03') cleanup; exit 0 ;;
        $'\x7f'|$'\b')
            [[ -n "$search" ]] && { search="${search[1,-2]}"; _prev_search="__init__"; scroll=0; first_sel; } ;;
        [[:print:]])
            search+="$key"; _prev_search="__init__"; scroll=0; first_sel ;;
    esac
    draw
done
